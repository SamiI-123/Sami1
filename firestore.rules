rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isVerified() {
      return isSignedIn(); // Relaxing for demo/dev speed, or use token.email_verified == true if strict
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.uid == 'SbDqWI1WCaWuXwRnbm26fXXJvk23' || request.auth.token.email == 'samsonabrhamtad@gmail.com');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATION BLUEPRINTS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return (data.uid == request.auth.uid || isAdmin())
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && (data.role == 'farmer' || data.role == 'expert' || data.role == 'admin')
        && data.keys().hasAll(['uid', 'email', 'displayName', 'role'])
        && data.keys().size() >= 4;
    }

    function isValidFarm(data) {
      return (data.ownerId == request.auth.uid || isAdmin())
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.createdAt == request.time
        && data.keys().hasAll(['ownerId', 'name', 'createdAt'])
        && data.keys().size() >= 3;
    }

    function isValidReport(data) {
      return (data.ownerId == request.auth.uid || isAdmin())
        && data.imageUrl is string && data.imageUrl.size() >= 10 && data.imageUrl.size() <= 2000000
        && data.findings is string && data.findings.size() <= 100000
        && data.status in ['pending', 'completed', 'error']
        && data.createdAt == request.time
        && data.keys().hasAll(['ownerId', 'imageUrl', 'status', 'createdAt', 'findings'])
        && data.keys().size() >= 5;
    }

    function isValidSensorData(data) {
      return data.farmId is string && data.farmId.size() <= 128
        && data.timestamp == request.time
        && data.moisture is number
        && data.temperature is number
        && data.humidity is number
        && data.keys().hasAll(['farmId', 'timestamp', 'moisture', 'temperature', 'humidity'])
        && data.keys().size() == 5;
    }

    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get, list, create, update, delete: if isAdmin();
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other users
      allow create: if isOwner(userId) && isValidUser(incoming()) && isVerified();
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'role', 'location', 'phoneNumber']);
    }

    match /farms/{farmId} {
      allow get, list, create, update, delete: if isAdmin();
      allow get: if isSignedIn() && isValidId(farmId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidFarm(incoming());
      allow update: if isOwner(existing().ownerId) && isValidFarm(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'location', 'size', 'cropType']);
      allow delete: if isOwner(existing().ownerId);
    }

    match /drone_sessions/{sessionId} {
      allow get, list, create, update, delete: if isAdmin();
      // Sessions relate to farms. Access check requires farm lookup.
      allow get: if isSignedIn() && isValidId(sessionId) 
        && isOwner(get(/databases/$(database)/documents/farms/$(existing().farmId)).data.ownerId);
      allow list: if false; // Force single-doc or subcollection usage if ever expanded
      allow create: if isVerified() && isValidId(incoming().farmId)
        && isOwner(get(/databases/$(database)/documents/farms/$(incoming().farmId)).data.ownerId);
    }

    match /ai_reports/{reportId} {
      allow get, list, create, update, delete: if isAdmin();
      allow get: if isOwner(existing().ownerId) && isValidId(reportId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidReport(incoming());
      allow update: if isOwner(existing().ownerId) && isValidReport(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['findings', 'status']);
      allow delete: if isOwner(existing().ownerId);
    }

    match /sensor_readings/{readingId} {
      allow get, list, create, update, delete: if isAdmin();
      allow read: if isSignedIn() && isValidId(readingId)
        && isOwner(get(/databases/$(database)/documents/farms/$(existing().farmId)).data.ownerId);
      allow list: if isSignedIn() && isOwner(get(/databases/$(database)/documents/farms/$(resource.data.farmId)).data.ownerId);
      allow create: if isVerified() && isValidSensorData(incoming())
        && isOwner(get(/databases/$(database)/documents/farms/$(incoming().farmId)).data.ownerId);
    }

    match /drones/{droneId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email;
    }

    match /system_settings/{settingId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn();
    }
  }
}
